# Personal deployment configuration for dustytrails
# Copy to deploy.config and customize for your environment

PI_HOST="raspberrypi.local"
PI_USER="pi"

# Secrets (injected into systemd service Environment)
DUSTY_PURPLEAIR_API_KEY="your-purpleair-api-key"
AIRNOW_API_KEY="your-airnow-api-key"
#DUSTY_OWNER_TOKEN="optional-owner-token"
